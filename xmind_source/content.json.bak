                {
                  "id": "81b476d1-836b-4a21-8e57-8b2d1e39d159",
                  "title": "1.3 CPU调度机制",
                  "titleUnedited": false,
                  "children": {
                    "attached": [
                      {
                        "id": "a561eb3d-c7b6-4e92-924a-fbf887fb04e2",
                        "title": "时间分片（Time Slicing）",
                        "titleUnedited": false,
                        "children": {
                          "attached": [
                            {
                              "id": "23372636-2b5c-41a2-8d93-86acf4c0c129",
                              "title": "CPU时间被划分为小的时间片（Linux通常1-10ms，Windows约15-30ms）",
                              "titleUnedited": false
                            },
                            {
                              "id": "bddfc10f-0dcd-4527-a18a-24569a560c99",
                              "title": "每个线程运行一个时间片后切换到下一个",
                              "titleUnedited": false
                            },
                            {
                              "id": "2cfa6d64-a9a0-47c8-a108-32c8f077405e",
                              "title": "通过时钟中断触发上下文切换",
                              "titleUnedited": false
                            }
                          ]
                        }
                      },
                      {
                        "id": "b2cefc8d-0eeb-42e4-b3b8-7c596967329c",
                        "title": "上下文切换（Context Switch）",
                        "titleUnedited": false,
                        "children": {
                          "attached": [
                            {
                              "id": "d267feba-3941-4fb2-9c1b-bc504540f472",
                              "title": "保存当前线程的CPU状态（寄存器、PC指针等）",
                              "titleUnedited": false
                            },
                            {
                              "id": "cdf4b8ce-5e47-474f-b555-4420c4492124",
                              "title": "恢复下一个线程的CPU状态",
                              "titleUnedited": false
                            },
                            {
                              "id": "17807fd5-4066-478b-8960-770c40758b44",
                              "title": "开销：内核态切换需要1-10μs，用户态切换约100-500ns（视硬件而定）",
                              "titleUnedited": false
                            }
                          ]
                        }
                      },
                      {
                        "id": "37654aeb-96ec-49a3-b2fc-697d45f0ceed",
                        "title": "调度算法",
                        "titleUnedited": false,
                        "children": {
                          "attached": [
                            {
                              "id": "c55dd463-7b17-4c98-b5b3-3b3a7e66ff9c",
                              "title": "FIFO（先来先服务）：简单但可能导致长任务阻塞短任务",
                              "titleUnedited": false
                            },
                            {
                              "id": "8e2d87eb-dd95-49a0-9a06-08aad56165b0",
                              "title": "Round Robin（轮转）：公平但上下文切换频繁",
                              "titleUnedited": false
                            },
                            {
                              "id": "44ff2a1c-8fcc-4bf9-a30b-1b885b0b4adc",
                              "title": "Priority Scheduling（优先级）：重要任务优先，但可能导致低优先级任务饥饿",
                              "titleUnedited": false
                            },
                            {
                              "id": "245633aa-e10d-45d6-9dac-755ebf8d237c",
                              "title": "Work Stealing（工作窃取）：空闲线程从忙碌线程窃取任务，Go的GMP（Goroutine，Machine（M），Processor（P））模型采用此算法",
                              "titleUnedited": false
                            }
                          ]
                        }
                      }
                    ]
                  }
