                {
                  "id": "727729b8-5dc0-4c75-9e27-576d10e25045",
                  "title": "1.4 多线程问题",
                  "titleUnedited": false,
                  "children": {
                    "attached": [
                      {
                        "id": "601cd674-54d8-4e39-98a9-7d345ce521fc",
                        "title": "竞态条件（Race Condition）",
                        "titleUnedited": false,
                        "children": {
                          "attached": [
                            {
                              "id": "35230156-bbaa-4900-a917-599f508f415b",
                              "title": "多个线程同时访问共享资源，且至少有一个写操作",
                              "titleUnedited": false
                            },
                            {
                              "id": "2cc27408-b71f-4db9-bb11-bc50cfee86be",
                              "title": "结果依赖于线程执行顺序",
                              "titleUnedited": false
                            },
                            {
                              "id": "a372aebe-3fc8-496b-9841-d2acb7d85a02",
                              "title": "例子：`counter++` 操作不是原子的",
                              "titleUnedited": false
                            }
                          ]
                        }
                      },
                      {
                        "id": "b17d5e0f-21bc-4183-b0e6-9f296ce11915",
                        "title": "死锁（Deadlock）",
                        "titleUnedited": false,
                        "children": {
                          "attached": [
                            {
                              "id": "9b655803-f5d2-4fc3-bb1a-c77ce4fe4b05",
                              "title": "两个或多个线程互相等待对方释放资源",
                              "titleUnedited": false
                            },
                            {
                              "id": "81f51b42-ed42-437f-995f-b2e659a5aab9",
                              "title": "产生条件：",
                              "titleUnedited": false,
                              "children": {
                                "attached": [
                                  {
                                    "id": "af10c3f3-698c-462a-8fd0-03034275aef8",
                                    "title": "互斥条件：资源不能共享",
                                    "titleUnedited": false
                                  },
                                  {
                                    "id": "c5865ce0-baa5-4e1a-9bc3-641e66bffe73",
                                    "title": "不可剥夺条件：资源只能由持有者释放",
                                    "titleUnedited": false
                                  },
                                  {
                                    "id": "feacaea4-9a71-423f-8f63-5abd2bbb5a55",
                                    "title": "请求与保持条件：持有资源同时请求新资源",
                                    "titleUnedited": false
                                  },
                                  {
                                    "id": "0f825ae2-dd43-4342-a921-1090f97c3d1c",
                                    "title": "循环等待条件：进程间形成循环等待链",
                                    "titleUnedited": false
                                  }
                                ]
                              }
                            }
                          ]
                        }
                      },
                      {
                        "id": "fb3fa179-08b2-464e-b967-a9fb41619304",
                        "title": "活锁（Livelock）",
