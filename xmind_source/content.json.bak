                {
                  "id": "1ae75bbf-f7e3-4112-a4f8-35ead79e1a8a",
                  "title": "1.1 进程 vs 线程",
                  "titleUnedited": false,
                  "children": {
                    "attached": [
                      {
                        "id": "44742486-8efb-44c5-8fee-380dfc907621",
                        "title": "进程（Process）",
                        "titleUnedited": false,
                        "children": {
                          "attached": [
                            {
                              "id": "c201b6be-7b5b-46e4-a1c0-1dc43b323bfd",
                              "title": "操作系统资源分配的基本单位",
                              "titleUnedited": false
                            },
                            {
                              "id": "64979020-3bfa-42bd-b766-e10c8944a27f",
                              "title": "拥有独立的内存空间（32位系统4GB，64位系统可达128TB+）",
                              "titleUnedited": false
                            },
                            {
                              "id": "d6731688-f409-4808-93b9-df45d368af49",
                              "title": "进程间通信需要IPC（管道、消息队列、共享内存等）",
