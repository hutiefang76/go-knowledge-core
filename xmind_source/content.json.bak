                  "id": "fec710fc-df24-496f-ba1d-fc314b04e5b2",
                  "title": "4.2.1 锁优化",
                  "titleUnedited": false,
                  "children": {
                    "attached": [
                      {
                        "id": "e9a1c9a6-592c-48d0-bd9f-2366c20263bb",
                        "title": "避免不必要的锁",
                        "titleUnedited": false,
                        "children": {
                          "attached": [
                            {
                              "id": "cc355150-6299-4b34-ade4-19ce4abc5071",
                              "title": "(代码块)",
                              "titleUnedited": false,
                              "children": {
                                "attached": [
                                  {
                                    "id": "073aa015-5149-4a1f-b244-ee1e65264450",
                                    "title": "(代码块)",
                                    "titleUnedited": false,
                                    "children": {
                                      "attached": [
                                        {
                                          "id": "9acadebf-01dc-4139-8fc2-350c9fd1f596",
                                          "title": "```go\n// 坏：整个函数加锁\nfunc badIncrement() {\n    mu.Lock()\n    defer mu.Unlock()\n    // 1. 读取配置（不需要锁）\n    config := readConfig()\n    // 2. 计算（不需要锁）\n    result := compute(config)\n    // 3. 更新共享状态（需要锁）\n    sharedData = result\n}\n\n// 好：只锁需要的部分\nfunc goodIncrement() {\n    config := readConfig()\n    result := compute(config)\n    \n    mu.Lock()\n    sharedData = result\n    mu.Unlock()\n}\n```",
                                          "titleUnedited": false
                                        }
                                      ]
                                    }
                                  }
                                ]
                              }
                            }
                          ]
                        }
                      },
                      {
                        "id": "73904049-260e-42c5-8756-9ddd4bd75f92",
                        "title": "使用细粒度锁",
                        "titleUnedited": false,
                        "children": {
                          "attached": [
                            {
                              "id": "533a56fe-0dbc-42a0-82b7-31ef805840cb",
                              "title": "(代码块)",
                              "titleUnedited": false,
                              "children": {
                                "attached": [
                                  {
                                    "id": "2b81979d-a5a5-4b4b-9449-21a6eac5eeef",
                                    "title": "(代码块)",
                                    "titleUnedited": false,
                                    "children": {
                                      "attached": [
                                        {
                                          "id": "af44e4d5-9177-4579-8986-51ce3838f77e",
                                          "title": "```go\n// 粗粒度锁\nvar globalMu sync.Mutex\nvar globalData map[string]int\n\n// 细粒度锁（分片）\ntype Shard struct {\n    mu   sync.Mutex\n    data map[string]int\n}\n\ntype ShardedMap []*Shard\n\nfunc (m ShardedMap) GetShard(key string) *Shard {\n    // 哈希分片\n    hash := fnv.New32a()\n    hash.Write([]byte(key))\n    shardIndex := hash.Sum32() % uint32(len(m))\n    return m[shardIndex]\n}\n```",
                                          "titleUnedited": false
                                        }
                                      ]
                                    }
                                  }
                                ]
                              }
                            }
                          ]
                        }
                      },
                      {
                        "id": "83338af3-bea0-4d15-9c15-49395466a6fc",
                        "title": "读写锁优化",
                        "titleUnedited": false,
                        "children": {
                          "attached": [
                            {
                              "id": "b3352387-9899-488e-bb2d-d6e188e38a17",
                              "title": "(代码块)",
                              "titleUnedited": false,
                              "children": {
                                "attached": [
                                  {
                                    "id": "0381b2aa-694a-4710-8122-a7ec8462a5e9",
                                    "title": "(代码块)",
                                    "titleUnedited": false,
                                    "children": {
                                      "attached": [
                                        {
                                          "id": "59661478-6849-435c-98ae-49a66fca91fa",
                                          "title": "```go\n// 读多写少场景使用RWMutex\nvar cache = struct {\n    mu   sync.RWMutex\n    data map[string]string\n}{data: make(map[string]string)}\n\nfunc Get(key string) string {\n    cache.mu.RLock()\n    defer cache.mu.RUnlock()\n    return cache.data[key]\n}\n\nfunc Set(key, value string) {\n    cache.mu.Lock()\n    defer cache.mu.Unlock()\n    cache.data[key] = value\n}\n```",
                                          "titleUnedited": false
                                        }
                                      ]
                                    }
                                  }
                                ]
                              }
                            }
                          ]
                        }
                      }
                    ]
