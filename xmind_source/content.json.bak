                },
                {
                  "id": "b7c659b6-5266-4251-910f-77722d1e69a4",
                  "title": "4.3 并发模式选择",
                  "titleUnedited": false,
                  "children": {
                    "attached": [
                      {
                        "id": "524648f5-ebd2-40ea-af03-a35029f411ff",
                        "title": "CPU密集 vs IO密集",
                        "titleUnedited": false,
                        "children": {
                          "attached": [
                            {
                              "id": "5cac8930-0665-42ba-8e9b-665057665983",
                              "title": "```go\n// ========== CPU密集型 ==========\n// 特征：没有网络/文件/数据库操作，纯计算\n\nfunc 压缩图片(img []byte) []byte {\n    for i := range img {\n        img[i] = 复杂算法处理(img[i])  // 一直在算\n    }\n    return img\n}\n\nfunc 计算优惠价格(order Order) float64 {\n    // 复杂的满减、折扣、积分抵扣计算\n    return 最终价格\n}\n\n// ========== IO密集型 ==========\n// 特征：大部分时间在等网络/数据库/文件响应\n\nfunc 查询物流(orderID string) Status {\n    resp, _ := http.Get(\"https://api.kuaidi.com/\" + orderID)  // 等网络\n    return 解析(resp)\n}\n\nfunc 查库存(productID int) int {\n    row := db.QueryRow(\"SELECT stock FROM products WHERE id=?\", productID)  // 等数据库\n    return stock\n}\n```",
                              "titleUnedited": false
                            },
                            {
                              "id": "13e89c9b-4989-4db3-80f0-86369a4bc423",
                              "title": "```go\n// CPU密集：goroutine数 ≈ CPU核心数\n// 开多了没用，CPU就那么多，反而增加切换开销\nworkers := runtime.NumCPU()  // 8核就开8个\n\n// IO密集：可以开很多\n// 反正大部分时间在等，多开几个能同时等更多请求\nfor i := 0; i < 1000; i++ {\n    go 调用外部API()  // 开1000个都行\n}\n```",
                              "titleUnedited": false
                            },
                            {
                              "id": "1c43b641-e2ab-458d-be25-bd7d4be0428d",
                              "title": "```go\nfunc 处理订单(order Order) {\n    库存 := 查库存(order.ProductID)    // IO密集：等数据库\n    价格 := 计算优惠价格(order, 库存)    // CPU密集：计算\n    调用支付API(order, 价格)           // IO密集：等网络\n    生成电子发票PDF(order)             // CPU密集：生成PDF\n}\n// 大部分时间花在IO → 当IO密集处理\n// 如果计算部分特别重 → 把CPU密集部分拆出来用Worker Pool\n```",
                              "titleUnedited": false
                            }
                          ]
                        }
                      },
                      {
                        "id": "2f731eca-86e1-4e4e-8aa5-9d632dff63ea",
                        "title": "Worker Pool模式 —— 工作池",
                        "titleUnedited": false,
                        "children": {
                          "attached": [
                            {
                              "id": "0e1ccd9b-aa7f-411b-9bfb-53d93689157b",
                              "title": "固定5个分拣员（worker）",
                              "titleUnedited": false
                            },
                            {
                              "id": "91513c6b-5236-48a8-a112-c46f45059b08",
                              "title": "订单（job）放进队列",
                              "titleUnedited": false
                            },
                            {
                              "id": "4eb8b4f5-7dde-43c3-8002-3bbd5af77426",
                              "title": "分拣员从队列取订单处理",
                              "titleUnedited": false
                            },
                            {
                              "id": "07ad896b-7ece-485a-9dcd-e6913295cabc",
                              "title": "不会因为1000个订单就招1000个人",
                              "titleUnedited": false,
                              "children": {
                                "attached": [
                                  {
                                    "id": "5647fd0b-14cf-4699-8b7b-64176098cb54",
                                    "title": "```go\nfunc main() {\n    jobs := make(chan Order, 100)    // 订单队列\n    results := make(chan Result, 100) // 结果队列\n\n    // 启动5个分拣员（固定数量）\n    for w := 1; w <= 5; w++ {\n        go 分拣员(w, jobs, results)\n    }\n\n    // 投递1000个订单\n    for i := 1; i <= 1000; i++ {\n        jobs <- Order{ID: i}\n    }\n    close(jobs)\n}\n\nfunc 分拣员(id int, jobs <-chan Order, results chan<- Result) {\n    for order := range jobs {\n        results <- 打包(order)\n    }\n}\n```",
                                    "titleUnedited": false
                                  }
                                ]
                              }
                            }
                          ]
                        }
                      },
                      {
                        "id": "0080c63d-a18c-43a9-95de-b435e93f85ea",
                        "title": "Pipeline模式 —— 流水线",
                        "titleUnedited": false,
                        "children": {
                          "attached": [
                            {
                              "id": "f325bddb-6202-4038-8876-3eb7ffb0e624",
                              "title": "```\n原料 → 切割 → 组装 → 包装 → 成品\n```",
                              "titleUnedited": false
                            },
                            {
                              "id": "3da5f3d1-fee0-4642-8062-317f48704a7d",
                              "title": "```go\n// 阶段1：生成订单\nfunc 接单() <-chan Order {\n    out := make(chan Order)\n    go func() {\n        for i := 1; i <= 10; i++ {\n            out <- Order{ID: i}\n        }\n        close(out)\n    }()\n    return out\n}\n\n// 阶段2：计算价格\nfunc 算价(in <-chan Order) <-chan Order {\n    out := make(chan Order)\n    go func() {\n        for order := range in {\n            order.Price = 计算(order)\n            out <- order\n        }\n        close(out)\n    }()\n    return out\n}\n\n// 串起来：接单 → 算价 → 发货\norders := 接单()\npriced := 算价(orders)\n```",
                              "titleUnedited": false
                            }
                          ]
                        }
                      },
                      {
                        "id": "82b6f666-49c9-4bf8-8fdb-ebb406334867",
                        "title": "Fan-out/Fan-in模式 —— 扇出/扇入",
                        "titleUnedited": false,
                        "children": {
                          "attached": [
                            {
                              "id": "36fb7854-5c04-472c-b031-d12388fe3275",
                              "title": "1000个订单，分给10个仓库同时处理",
                              "titleUnedited": false
                            },
                            {
                              "id": "a9201aa6-e529-4f78-99f1-3e4297bd2dd2",
                              "title": "一个输入，多个处理者",
                              "titleUnedited": false
                            },
                            {
                              "id": "d8cea859-89ff-4221-835f-f49f6b302883",
                              "title": "10个仓库的发货结果，汇总到一个报表",
                              "titleUnedited": false
                            },
                            {
                              "id": "3d3b139a-da18-4730-9395-20a5ac2bf194",
                              "title": "多个输入，合并成一个输出",
                              "titleUnedited": false,
                              "children": {
                                "attached": [
                                  {
                                    "id": "8098293e-9b26-4063-ba7d-5e9cee96349e",
                                    "title": "```\n        ┌→ 仓库1 ─┐\n订单队列 ─┼→ 仓库2 ─┼→ 汇总报表\n        └→ 仓库3 ─┘\n     (Fan-out)  (Fan-in)\n```",
                                    "titleUnedited": false
                                  },
                                  {
                                    "id": "8ba64554-e415-4aac-b1ec-9a8916509d1a",
                                    "title": "```go\n// Fan-out：多个worker抢同一个channel\njobs := make(chan Order, 100)\nfor i := 0; i < 10; i++ {\n    go 仓库处理(jobs, results)  // 10个仓库抢着处理\n}\n\n// Fan-in：多个channel合并成一个\nfunc 汇总(channels ...<-chan Result) <-chan Result {\n    out := make(chan Result)\n    var wg sync.WaitGroup\n    for _, ch := range channels {\n        wg.Add(1)\n        go func(c <-chan Result) {\n            defer wg.Done()\n            for r := range c {\n                out <- r\n            }\n        }(ch)\n    }\n    go func() { wg.Wait(); close(out) }()\n    return out\n}\n```",
                                    "titleUnedited": false
                                  }
                                ]
                              }
                            }
                          ]
                        }
                      },
