                            },
                            {
                              "id": "e33f3eae-0fad-429b-b8fe-a57ec91854ab",
                              "title": "无缓冲channel：适合同步通信，严格顺序",
                              "titleUnedited": false
                            },
                            {
                              "id": "7e452a40-fdae-4b21-80ad-ba1b13acbe8a",
                              "title": "有缓冲channel：适合异步通信，减少阻塞",
                              "titleUnedited": false
